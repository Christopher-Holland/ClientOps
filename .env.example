# Database (PostgreSQL)
# Use a connection string like: postgresql://user:password@localhost:5432/clientops
DATABASE_URL="postgresql://user:password@localhost:5432/clientops"

# Stack Auth (https://stack-auth.com)
# Create a project at https://app.stack-auth.com to get these values
NEXT_PUBLIC_STACK_PROJECT_ID="your-stack-project-id"
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY="your-stack-publishable-client-key"
